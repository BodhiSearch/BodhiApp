{
  "name": "@bodhiapp/ts-client",
  "version": "0.1.31-dev",
  "description": "TypeScript types for Bodhi API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./openai": {
      "types": "./dist/openai.d.ts",
      "import": "./dist/openai.mjs",
      "require": "./dist/openai.js"
    },
    "./anthropic": {
      "types": "./dist/anthropic.d.ts",
      "import": "./dist/anthropic.mjs",
      "require": "./dist/anthropic.js"
    },
    "./gemini": {
      "types": "./dist/gemini.d.ts",
      "import": "./dist/gemini.mjs",
      "require": "./dist/gemini.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run generate && npm run bundle",
    "build:openapi": "npm run generate:types && npm run generate:types-oai && npm run generate:types-anthropic && npm run generate:types-gemini && npm run generate:msw-types && npm run generate:msw-types-oai && npm run generate:msw-types-anthropic && npm run generate:msw-types-gemini && npm run bundle",
    "generate": "npm run generate:openapi && npm run generate:openapi-oai && npm run generate:types && npm run generate:types-oai && npm run generate:types-anthropic && npm run generate:types-gemini && npm run generate:msw-types && npm run generate:msw-types-oai && npm run generate:msw-types-anthropic && npm run generate:msw-types-gemini",
    "generate:openapi": "cd .. && cargo run --package xtask openapi",
    "generate:openapi-oai": "cd .. && cargo run --package xtask openapi-oai",
    "generate:types": "openapi-ts",
    "generate:types-oai": "openapi-ts --file openapi-ts-oai.config.ts",
    "generate:msw-types": "openapi-typescript ../openapi.json -o src/openapi-typescript/openapi-schema.ts",
    "generate:types-anthropic": "openapi-ts --file openapi-ts-anthropic.config.ts",
    "generate:types-gemini": "openapi-ts --file openapi-ts-gemini.config.ts",
    "generate:msw-types-oai": "openapi-typescript ../openapi-oai.json -o src/openapi-typescript/openapi-schema-oai.ts",
    "generate:msw-types-anthropic": "openapi-typescript openapi-anthropic.json -o src/openapi-typescript/openapi-schema-anthropic.ts",
    "generate:msw-types-gemini": "openapi-typescript openapi-gemini.json -o src/openapi-typescript/openapi-schema-gemini.ts",
    "sync:openapi-gemini": "node scripts/sync-gemini-openapi.mjs",
    "bundle": "npm run bundle:types && npm run bundle:esm && npm run bundle:cjs",
    "bundle:types": "tsc --emitDeclarationOnly --outDir dist && cpy 'src/types/**' 'dist/types' && cpy 'src/types-oai/**' 'dist/types-oai' && cpy 'src/types-anthropic/**' 'dist/types-anthropic' && cpy 'src/types-gemini/**' 'dist/types-gemini' && cpy 'src/openapi-typescript/**' 'dist/openapi-typescript'",
    "bundle:esm": "esbuild src/index.ts src/openai.ts src/anthropic.ts src/gemini.ts --bundle --platform=neutral --format=esm --outdir=dist --out-extension:.js=.mjs --external:./types --external:./types-oai --external:./types-anthropic --external:./types-gemini --allow-overwrite",
    "bundle:cjs": "esbuild src/index.ts src/openai.ts src/anthropic.ts src/gemini.ts --bundle --platform=neutral --format=cjs --outdir=dist --external:./types --external:./types-oai --external:./types-anthropic --external:./types-gemini --allow-overwrite",
    "test": "vitest run",
    "clean": "rm -rf dist && rm -rf src/types && rm -rf src/types-oai && rm -rf src/types-anthropic && rm -rf src/types-gemini && rm -rf src/openapi-typescript"
  },
  "keywords": [
    "bodhi",
    "api",
    "types",
    "typescript"
  ],
  "author": "Bodhi Team",
  "license": "Apache-2.0",
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.64.15",
    "@types/node": "^22.13.14",
    "cpy-cli": "^5.0.0",
    "esbuild": "^0.20.2",
    "msw": "^2.7.3",
    "openapi-format": "^1.30.1",
    "openapi-typescript": "^7.9.1",
    "typescript": "^5.3.3",
    "vitest": "^3.0.9"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
