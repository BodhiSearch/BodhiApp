# Multi-tenant Docker runtime environment variables
# Copy this file to .env.local and fill in real values:
#   cp devops/.env.example devops/.env.local

BODHI_LOG_STDOUT=true
BODHI_LOG_LEVEL=debug
BODHI_ENCRYPTION_KEY=your-encryption-key-here
BODHI_PUBLIC_HOST=localhost
BODHI_PUBLIC_PORT=1135
BODHI_APP_DB_URL=postgres://bodhi_dev:bodhi_dev@host.docker.internal:44320/bodhi_app
BODHI_SESSION_DB_URL=postgres://bodhi_dev:bodhi_dev@host.docker.internal:44321/bodhi_sessions
BODHI_MULTITENANT_CLIENT_ID=your-client-id-here
BODHI_MULTITENANT_CLIENT_SECRET=your-client-secret-here
